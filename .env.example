# Copy to .env and edit. Values here are consumed by docker-compose.yml.

# --- Windows edition ---
# See https://github.com/dockur/windows for the full list.
# 11l = Windows 11 LTSC
WINDOWS_VERSION=11l

# --- Resources ---
RAM_SIZE=8G
CPU_CORES=4
DISK_SIZE=128G

# --- RDP / web credentials ---
WIN_USERNAME=admin
WIN_PASSWORD=changeme

# --- Host port bindings ---
WEB_PORT=8006
RDP_PORT=3389

# --- Locale (passed to dockur) ---
WIN_LANGUAGE=English
WIN_KEYBOARD=en-US
WIN_REGION=en-US
