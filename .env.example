# Copy to .env and edit. Values here are consumed by docker-compose.yml.

# --- Windows edition ---
# See https://github.com/dockur/windows for the full list.
# 10  = Windows 10 Pro (recommended - non-eval, activates permanently with TSforge)
# 10l = Windows 10 LTSC (eval-only ISO, TIMEBASED_EVAL channel - TSforge cannot activate it)
# 11  = Windows 11 Pro (if Win 11 APIs are needed)
WINDOWS_VERSION=10

# --- Resources ---
RAM_SIZE=8G
CPU_CORES=4
DISK_SIZE=64G

# --- RDP / web credentials ---
WIN_USERNAME=admin
WIN_PASSWORD=changeme

# --- Host port bindings ---
WEB_PORT=8006
RDP_PORT=3389

# --- Locale (passed to dockur) ---
WIN_LANGUAGE=English
WIN_KEYBOARD=en-US
WIN_REGION=en-US
