# Copy to git-credentials.txt and edit (gitignored).
# One line per host, in git's plaintext credential-store format:
#
#   https://USERNAME:TOKEN@github.com
#   https://USERNAME:TOKEN@gitlab.com
#
# install.bat copies this file to %USERPROFILE%\.git-credentials inside the VM
# and configures `git config --global credential.helper store`.
# The source file is then deleted from C:\OEM during cleanup.
#
# Tokens stay on the VM disk in cleartext — fine for a dev VM, not for prod.
https://YOUR_USERNAME:YOUR_PERSONAL_ACCESS_TOKEN@github.com
